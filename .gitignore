# Unity package manager cache (optional; keep repo smaller)
unity_test/Library/PackageCache/

# If you imported a git repo into Assets, don't commit its internal git dir
unity_test/Assets/**/.git/

# Arduino / PlatformIO build outputs (sketches under test/)
**/.pio/
**/build/
**/*.elf
**/*.hex
**/*.bin

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.tmp

# Secrets (keep these out of git if you create them later)
.env
.env.*
